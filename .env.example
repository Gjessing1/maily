# Copy to .env (kept out of git). In production this lives at /home/gjessing/docker/maily/.env

# --- Runtime ---
NODE_ENV=development
PORT=3000

# --- Persistent data ---
# Locally defaults to ./data. In Docker this is the mounted host volume.
MAILY_DATA_DIR=/mnt/data/maily
MAILY_DB_FILE=mail.sqlite

# --- Auth (Phase 2) ---
JWT_SECRET=change-me-to-a-long-random-string
MASTER_PASSWORD=change-me

# --- Web Push / VAPID (Phase 2) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:larsgjessing@gmail.com

# --- Mail accounts (Phase 1) ---
# One block per account, numbered from 1. Credentials are backend-only, never
# exposed to the frontend. PROVIDER drives capability branching ('gmail' | 'imap').
# USER/SMTP_USER/SMTP_PASSWORD default to EMAIL/PASSWORD; *_SECURE defaults from the port.
# ACCOUNT_1_PROVIDER=gmail
# ACCOUNT_1_EMAIL=larsgjessing@gmail.com
# ACCOUNT_1_DISPLAY_NAME=Lars
# ACCOUNT_1_IMAP_HOST=imap.gmail.com
# ACCOUNT_1_IMAP_PORT=993
# ACCOUNT_1_SMTP_HOST=smtp.gmail.com
# ACCOUNT_1_SMTP_PORT=465
# ACCOUNT_1_USER=larsgjessing@gmail.com
# ACCOUNT_1_PASSWORD=app-specific-password
#
# ACCOUNT_2_PROVIDER=imap
# ACCOUNT_2_EMAIL=me@mailbox.org
# ACCOUNT_2_IMAP_HOST=imap.mailbox.org
# ACCOUNT_2_SMTP_HOST=smtp.mailbox.org
# ACCOUNT_2_PASSWORD=app-specific-password
